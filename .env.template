# hepta-md-sync 環境變數範本
# 複製此檔案為 .env 並填入實際值

# Heptabase 資料庫路徑 (SQLite)
# macOS 預設位置: ~/Library/Application Support/project-meta/hepta.db
HEPTA_DB_PATH=/path/to/your/hepta.db

# Markdown 輸出目錄
# 建議使用絕對路徑或 ~ 開頭的路徑
OUTPUT_DIR=/path/to/your/output

# 未指定 whiteboard 的 card 放置資料夾名稱
ORPHAN_DIR=_Inbox

# 是否自動 git commit (true/false)
GIT_COMMIT=true

# 狀態檔路徑 (記錄增量同步狀態)
STATE_FILE=~/.heptabase_sync_state.json

# 日誌檔路徑
LOG_FILE=~/Library/Logs/heptabase_sync.log

# MCP Bridge 腳本路徑
# 請填入此專案中 md_to_heptabase.py 的完整路徑
MCP_BRIDGE_PATH=/path/to/your/project/md_to_heptabase.py

# MCP 指令 (預設使用 bunx heptabase-mcp)
# 如果需要指定完整路徑或其他執行方式，可在此修改
MCP_COMMAND=bunx heptabase-mcp
